DEBUG=false
PORT=3718
CORS_ORIGINS=["http://localhost:3717"]

# --- LangSmith tracing (optional) -------------------------------------------
# Absent/unset => tracing is a no-op. Set these to trace EDA runs in LangSmith.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=eda-agentic
# Mask prompt inputs/outputs (which embed uploaded-data samples) from traces.
# Leave enabled unless you explicitly need to inspect prompt payloads.
# LANGCHAIN_HIDE_INPUTS=true
# LANGCHAIN_HIDE_OUTPUTS=true
